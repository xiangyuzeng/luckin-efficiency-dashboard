# Public env vars (must be NEXT_PUBLIC_* to be visible at build time on Vercel).

# When "true", the "导出数据" button opens the export-gate modal and requires a passphrase
# for the unfiltered/full export. The current-view export remains open.
NEXT_PUBLIC_EXPORT_REQUIRE_AUTH=false

# SHA-256 hex of the passphrase that unlocks the full export.
# Compute with: echo -n "your-passphrase" | shasum -a 256
NEXT_PUBLIC_EXPORT_PASSPHRASE_HASH=
