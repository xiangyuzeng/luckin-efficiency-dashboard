# Copy to pipeline/.env and fill in real values. .env is gitignored.
# Required by the in-container scheduler (pipeline/scheduler/cron_runner.py).

# ── MySQL credentials (AWS Secrets Manager) ────────────────────────
AWS_REGION=us-east-1
MYSQL_SECRET_ID=collector/mysql
# If running on a host without an IAM role, set these too.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Host resolution: collectors only query luckyus_sales_order. The pipeline
# reads pipeline/config/rds_instances.json to find the RDS instance ID and
# calls rds:DescribeDBInstances to get the live FQDN. IAM permission
# required (in addition to secretsmanager:GetSecretValue):
#   rds:DescribeDBInstances on the salesorder instance.
# Set SALESORDER_HOST to short-circuit the boto3 lookup if needed.
# SALESORDER_HOST=

# ── GitHub push ────────────────────────────────────────────────────
# Token needs `contents:write` on the target repo only — no other scopes.
GITHUB_TOKEN=
GITHUB_REPO=xiangyuzeng/luckin-efficiency-dashboard
GITHUB_BRANCH=main
GITHUB_DAILY_PATH=data/efficiency.json
GITHUB_REALTIME_PATH=data/realtime.json

# ── Pipeline tuning ────────────────────────────────────────────────
LOG_DIR=/workspace/logs

# ── Daily cron schedule ────────────────────────────────────────────
# When to run the heavy 180-day refresh. Defaults to 01:00 US/Eastern
# (off-peak for MySQL load and for operator dashboards).
#   DAILY_TIMEZONE  IANA zone (US/Eastern, Asia/Shanghai, UTC, …)
#   DAILY_HOUR      0-23
#   DAILY_MINUTE    0-59
DAILY_TIMEZONE=US/Eastern
DAILY_HOUR=1
DAILY_MINUTE=0

# ── Realtime cron schedule ─────────────────────────────────────────
# Realtime cadence is policy — change these to retune without redeploying.
#   REALTIME_TIMEZONE     IANA zone name (US/Eastern, Asia/Shanghai, UTC, …)
#   REALTIME_HOURS        hour expression: "7-19" (range), "9,12,15" (list),
#                         "8-10,14-16" (ranges), "*" (every hour)
#   REALTIME_INTERVAL_MIN minute interval; the cron uses */N
# Defaults gate to Manhattan store hours (52 ticks/day, vs 96 for 24/7).
REALTIME_TIMEZONE=US/Eastern
REALTIME_HOURS=7-19
REALTIME_INTERVAL_MIN=15
